FROM python:3.12-slim

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

COPY pyproject.toml ./
COPY packages/proxy/pyproject.toml packages/proxy/

RUN cd packages/proxy && uv sync --no-dev

COPY packages/proxy/src packages/proxy/src

EXPOSE 8080

CMD ["uv", "run", "--directory", "packages/proxy", "uvicorn", "agentshield_proxy.app:app", "--host", "0.0.0.0", "--port", "8080"]
