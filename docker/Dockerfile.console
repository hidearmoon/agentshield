FROM python:3.12-slim

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

COPY pyproject.toml ./
COPY packages/console/backend/pyproject.toml packages/console/backend/

RUN cd packages/console/backend && uv sync --no-dev

COPY packages/console/backend/src packages/console/backend/src

EXPOSE 8100

CMD ["uv", "run", "--directory", "packages/console/backend", "uvicorn", "agentguard_console.app:app", "--host", "0.0.0.0", "--port", "8100"]
