          "all_allowed"
        ],
        "title": "BatchCheckResponse"
      },
      "CheckRequest": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "tool_name": {
            "type": "string",
            "title": "Tool Name"
          },
          "params": {
            "additionalProperties": true,
            "type": "object",
            "title": "Params"
          },
          "sdk_version": {
            "type": "string",
            "title": "Sdk Version",
            "default": ""
          },
          "source_id": {
            "type": "string",
            "title": "Source Id",
            "default": ""
          },
          "client_trust_level": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Trust Level"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "tool_name"
        ],
        "title": "CheckRequest"
      },
      "CheckResponse": {
        "properties": {
          "action": {
            "type": "string",
            "title": "Action"
          },
          "reason": {
            "type": "string",
            "title": "Reason",
            "default": ""
          },
          "trace_id": {
            "type": "string",
            "title": "Trace Id",
            "default": ""
          },
          "span_id": {
            "type": "string",
            "title": "Span Id",
            "default": ""
          },
          "engine": {
            "type": "string",
            "title": "Engine",
            "default": ""
          },
          "trust_level": {
            "type": "string",
            "title": "Trust Level",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "action"
        ],
        "title": "CheckResponse"
      },
      "CreateSessionRequest": {
        "properties": {
          "user_message": {
            "type": "string",
            "title": "User Message"
          },
          "agent_id": {
            "type": "string",
            "title": "Agent Id",
            "default": ""
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "user_message"
        ],
        "title": "CreateSessionRequest"
      },
      "ExtractRequest": {
        "properties": {
          "data": {
            "type": "string",
            "title": "Data"
          },
          "schema_name": {
            "type": "string",
            "title": "Schema Name"
          }
        },
        "type": "object",
        "required": [
          "data",
          "schema_name"
